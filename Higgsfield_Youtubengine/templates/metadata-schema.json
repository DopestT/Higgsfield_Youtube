{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Higgsfield_Youtubengine video metadata",
  "type": "object",
  "required": ["slug", "date", "idea", "primary_title", "description", "hashtags", "format", "scenes"],
  "properties": {
    "slug": { "type": "string" },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "idea": { "type": "string" },
    "title_options": { "type": "array", "items": { "type": "string" } },
    "primary_title": { "type": "string" },
    "description": { "type": "string" },
    "hashtags": { "type": "array", "minItems": 5, "maxItems": 5, "items": { "type": "string" } },
    "format": {
      "type": "object",
      "required": ["aspect_ratio", "target_seconds", "scene_count"],
      "properties": {
        "aspect_ratio": { "type": "string", "enum": ["9:16"] },
        "target_seconds": { "type": "number", "minimum": 30, "maximum": 60 },
        "scene_count": { "type": "number", "minimum": 5, "maximum": 8 },
        "seconds_per_scene_range": { "type": "string" }
      }
    },
    "platforms": { "type": "array", "items": { "type": "string" } },
    "tone": { "type": "string" },
    "style": { "type": "string" },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["n", "beat", "start", "end", "duration"],
        "properties": {
          "n": { "type": "number" },
          "beat": { "type": "string" },
          "start": { "type": "number" },
          "end": { "type": "number" },
          "duration": { "type": "number", "minimum": 4, "maximum": 7 },
          "camera": { "type": "string" },
          "motion": { "type": "string" },
          "lighting": { "type": "string" },
          "voiceover": { "type": "string" }
        }
      }
    },
    "assets": { "type": "object" },
    "status": { "type": "string", "enum": ["draft", "in-production", "rendered", "published"] },
    "generated_by": { "type": "string" }
  }
}
